# 本文件同时被 docker compose 读取（镜像名变量）并注入 backend 容器（DATABASE_URL 等）。
# 若 build 拉取 python/postgres 超时，可取消下面两行注释（镜像站以当时可用为准，见 docker/README.md）
# DOCKER_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
# DOCKER_POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:15

# backend container env
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://family_ai:family_ai_password@db:5432/family_ai
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

PUBLIC_BASE_URL=https://app.nasclaw.com
CORS_ALLOW_ORIGINS=https://app.nasclaw.com
# HTTPS 反代终止 TLS 时必须为 true；若暂时只用 http://IP:8000 直连（无证书）则改为 false
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# Brave 等敏感配置落库加密（须为合法 Fernet 密钥，不能填普通密码）
# 生成：python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_FERNET_KEY=

# 无 Supabase 时：STORAGE_DRIVER=local 且 Docker 需 LOCAL_STORAGE_ROOT=/data/uploads（见 compose 卷）
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/data/uploads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=family-ai-attachments

# Tencent COS（推荐：App 直传 COS，后端只签名+commit；模型侧通过 COS URL 下载图片）
COS_REGION=ap-singapore
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
# 可选：走 CDN 自定义域名（公开读）时填你的静态资源根 URL
COS_PUBLIC_BASE_URL=

# 旧版联网开关（聊天主流程已用 Brave；可保留默认）
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=5

# ---------- LLM（变量名须与 backend/app/core/config.py 中 Settings 一致）----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_PROXY=http://127.0.0.1:7890
# chatgpt-5.2 / chatgpt-5.4 路由对应的 OpenAI model id
OPENAI_MODEL_CHATGPT_52=gpt-5.2
OPENAI_MODEL_CHATGPT_54=gpt-5.4
# 含图片附件时 ChatGPT 路线使用的 vision 模型
OPENAI_MODEL_VISION=gpt-5.4

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_PROXY=http://127.0.0.1:7890
# 官方：deepseek-chat / deepseek-reasoner 等，见 api-docs.deepseek.com
DEEPSEEK_MODEL_TEXT=deepseek-chat

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_FLASH=gemini-3-flash-preview
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
# GEMINI_PROXY=http://127.0.0.1:7890

# ---------- 智能化流水线（与 backend/.env.example 对齐）----------
FEATURE_TASK_CLASSIFICATION=true
FEATURE_STRUCTURED_PROMPTS=true
FEATURE_CONTEXT_COMPRESSION=true
FEATURE_OUTPUT_VALIDATION=true
FEATURE_SEARCH_AUTO_TRIGGER=true
FEATURE_SEARCH_STRUCTURED_INJECTION=true
PROMPT_TEMPLATES_HOT_RELOAD=false
MAX_CONTEXT_TURNS=20
CONTEXT_HISTORY_TOKEN_BUDGET=24000
CLASSIFIER_MODEL=gpt-4o-mini
# 无 OpenAI Key、用 DeepSeek 做任务分类时的 model（建议保持 deepseek-chat）
CLASSIFIER_MODEL_DEEPSEEK=deepseek-chat
CLASSIFIER_TIMEOUT_MS=2500
