# 本文件同时被 docker compose 读取（镜像名变量）并注入 backend 容器（DATABASE_URL 等）。
# 若 build 拉取 python/postgres 超时，可取消下面两行注释（镜像站以当时可用为准，见 docker/README.md）
# DOCKER_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
# DOCKER_POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:15

# backend container env（线上正式：PUBLIC_BASE_URL / CORS / SESSION 须与 HTTPS 反代一致）
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://family_ai:family_ai_password@db:5432/family_ai
JWT_SECRET=7CZafooOvttspsq8RuKSkddK6PiBcTgChIpsxFgZIPW_TqQhDYDTDUkPFSSo5sjE
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200

ADMIN_USERNAME=admin
ADMIN_PASSWORD=317213794

# 对外唯一域名（管理后台、API、生成链接等均基于此；须 HTTPS 反代到本服务）
PUBLIC_BASE_URL=https://app.nasclaw.com
CORS_ALLOW_ORIGINS=https://app.nasclaw.com
# HTTPS 反代终止 TLS 时必须为 true；仅 http://IP:8000 直连调试时改为 false
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# Brave 等敏感配置落库加密（管理后台保存 Brave Key 需要；可本地生成 Fernet 密钥）
# 须为 Fernet 格式（python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
FIELD_ENCRYPTION_FERNET_KEY=vZksQVJ2desWQFYVfWALyLcoHzDe_4C5SwKKIKrUPHI=

# 本地无 Supabase 时用 local；compose 将卷挂载到 /data/uploads
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/data/uploads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=family-ai-attachments

WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=5

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_TEXT=deepseek-chat
