# =========================
# Server
# =========================
APP_NAME="Family AI Assistant"
ENVIRONMENT="dev"
LOG_LEVEL="INFO"

# 部署到公网时填写你的域名（用于生成可访问链接等）
PUBLIC_BASE_URL="https://ai.nasclaw.com"

# CORS (第一版仅家庭内部使用；可按需放开)
CORS_ALLOW_ORIGINS="https://ai.nasclaw.com"

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_URL="postgresql+psycopg://family_ai:family_ai_password@localhost:5432/family_ai"

# =========================
# Auth (JWT)
# =========================
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES="43200"  # 30天，家庭内部使用第一版

# 初始化管理员（第一次启动会自动创建；若已存在则忽略）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"

# =========================
# LLM Keys (ONLY on server)
# =========================
# 必填：对话（ChatGPT 路线）依赖此 Key；勿提交到 Git
OPENAI_API_KEY=""
# 官方：https://api.openai.com/v1 ；第三方兼容网关可改 BASE_URL
# 若日志/接口报「Server disconnected」或无法连接：多为网络到 OpenAI 被中断。
# 可在运行后端的 shell 导出 HTTPS_PROXY，或换可访问的兼容 BASE_URL + 对应 Key。
OPENAI_BASE_URL="https://api.openai.com/v1"
# chatgpt-5.2 / chatgpt-5.4 路由对应的 OpenAPI model id（可改为快照 id）
OPENAI_MODEL_CHATGPT_52="gpt-5.2"
OPENAI_MODEL_CHATGPT_54="gpt-5.4"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL_TEXT="deepseek-chat"

# =========================
# Web Search (ChatGPT route only)
# =========================
WEB_SEARCH_ENABLED="true"
WEB_SEARCH_TIMEOUT_SECONDS="8"
WEB_SEARCH_MAX_RESULTS="5"

# =========================
# Storage (第一版默认本地存储，接口仍走 presign/commit)
# =========================
STORAGE_DRIVER="local"  # local | supabase

# local storage root (mounted volume in docker or local dir)
LOCAL_STORAGE_ROOT="./.data/uploads"

# Supabase（可选）
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="family-ai-attachments"

# 管理后台 cookie（部署到 HTTPS 后建议开启）
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="lax"
