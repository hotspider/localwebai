# =========================
# Server
# =========================
APP_NAME="Family AI Assistant"
# 线上 Docker / 服务器：production；本机 uvicorn 联调可改为 dev
ENVIRONMENT="production"
LOG_LEVEL="INFO"

# 部署到公网时填写你的域名（用于生成可访问链接等）
PUBLIC_BASE_URL="https://app.nasclaw.com"

# CORS (第一版仅家庭内部使用；可按需放开)
CORS_ALLOW_ORIGINS="https://app.nasclaw.com"

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_URL="postgresql+psycopg://family_ai:family_ai_password@localhost:5432/family_ai"

# =========================
# Auth (JWT)
# =========================
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES="43200"  # 30天，家庭内部使用第一版

# 初始化管理员（第一次启动会自动创建；若已存在则忽略）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"

# =========================
# LLM Keys (ONLY on server)
# =========================
# 必填：对话（ChatGPT 路线）依赖此 Key；勿提交到 Git
OPENAI_API_KEY=""
# 官方：https://api.openai.com/v1 ；第三方兼容网关可改 BASE_URL
# 若日志/接口报「Server disconnected」或无法连接：多为网络到 OpenAI 被中断。
# 可在运行后端的 shell 导出 HTTPS_PROXY，或换可访问的兼容 BASE_URL + 对应 Key。
OPENAI_BASE_URL="https://api.openai.com/v1"
# chatgpt-5.2 / chatgpt-5.4 路由对应的 OpenAPI model id（可改为快照 id）
OPENAI_MODEL_CHATGPT_52="gpt-5.2"
OPENAI_MODEL_CHATGPT_54="gpt-5.4"
OPENAI_MODEL_VISION="gpt-5.4"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_PROXY="http://127.0.0.1:7890"
# 官方 API：deepseek-chat=对话（随平台升级）；deepseek-reasoner=推理
DEEPSEEK_MODEL_TEXT="deepseek-chat"

# Google Gemini（generativelanguage.googleapis.com；Key 也可仅在管理后台「LLM 配置」保存）
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_MODEL_FLASH="gemini-3-flash-preview"
GEMINI_MODEL_PRO="gemini-3.1-pro-preview"
# GEMINI_PROXY="http://127.0.0.1:7890"

# =========================
# 智能化流水线（任务分类 / 模板化 Prompt / 搜索策略 / 输出校验）
# =========================
FEATURE_TASK_CLASSIFICATION=true
FEATURE_STRUCTURED_PROMPTS=true
FEATURE_CONTEXT_COMPRESSION=true
FEATURE_OUTPUT_VALIDATION=true
FEATURE_SEARCH_AUTO_TRIGGER=true
FEATURE_SEARCH_STRUCTURED_INJECTION=true
PROMPT_TEMPLATES_HOT_RELOAD=false
MAX_CONTEXT_TURNS=20
CONTEXT_HISTORY_TOKEN_BUDGET=24000
CLASSIFIER_MODEL=gpt-4o-mini
# 无 OpenAI Key、用 DeepSeek 做任务分类时的 model（建议保持 deepseek-chat）
CLASSIFIER_MODEL_DEEPSEEK=deepseek-chat
# 轻量分类调用超时（毫秒）；纯 HTTP 很难稳定 <200ms，默认 2500
CLASSIFIER_TIMEOUT_MS=2500

# =========================
# 敏感字段落库加密（管理后台保存的 OpenAI / DeepSeek / Brave 等 API Key 写入 DB 前加密）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =========================
FIELD_ENCRYPTION_FERNET_KEY=""

# =========================
# 旧版 DuckDuckGo 联网（聊天主流程已改为仅 Brave；可忽略）
# =========================
WEB_SEARCH_ENABLED="true"
WEB_SEARCH_TIMEOUT_SECONDS="8"
WEB_SEARCH_MAX_RESULTS="5"

# =========================
# Storage (第一版默认本地存储，接口仍走 presign/commit)
# =========================
STORAGE_DRIVER="local"  # local | supabase

# local storage root (mounted volume in docker or local dir)
LOCAL_STORAGE_ROOT="./.data/uploads"

# Supabase（可选）
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="family-ai-attachments"

# 管理后台 cookie（部署到 HTTPS 后建议开启）
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="lax"
